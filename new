            const SizedBox(width: 14),
            Expanded(
              child: Text(
                goal['title'],
                style: TextStyle(
                  fontSize: 14,
                  color: goal['done'] ? kPrimaryColor : kTextDark,
                  decoration: goal['done']
                      ? TextDecoration.lineThrough
                      : TextDecoration.none,
                  fontWeight: goal['done']
                      ? FontWeight.normal
                      : FontWeight.w500,
                ),
              ),
            ),
            AnimatedSwitcher(
              duration: const Duration(milliseconds: 300),
              child: Icon(
                goal['done']
                    ? Icons.check_circle
                    : Icons.radio_button_unchecked,
                key: ValueKey(goal['done']),
                color: goal['done'] ? kPrimaryColor : Colors.grey,
                size: 24,
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildWellnessTip() {
    return Container(
      padding: const EdgeInsets.all(18),
      decoration: BoxDecoration(
        color: const Color(0xFFFFF8E1),
        borderRadius: BorderRadius.circular(18),
        border: Border.all(color: const Color(0xFFFFCC02), width: 1.5),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: const [
          Row(
            children: [
              Icon(Icons.lightbulb, color: Color(0xFFFFAB00), size: 22),
              SizedBox(width: 8),
              Text(
                'Wellness Tip of the Day',
                style: TextStyle(
                  fontWeight: FontWeight.bold,
                  color: Color(0xFF7B5800),
                  fontSize: 15,
                ),
              ),
            ],
          ),
          SizedBox(height: 10),
          Text(
            'Social connections are vital for wellbeing. '
                'Spending quality time with people you care about reduces '
                'stress hormones, boosts immunity, and can even lengthen '
                'your life. Aim for at least one meaningful conversation today.',
            style: TextStyle(
              color: Color(0xFF5D4037),
              fontSize: 13,
              height: 1.6,
            ),
          ),
        ],
      ),
    );
  }
}

