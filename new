  State<HomeTab> createState() => _HomeTabState();
}

class _HomeTabState extends State<HomeTab> {
  final List<Map<String, dynamic>> _goals = [
    {'title': 'Meditate for 10 minutes', 'done': false, 'icon': Icons.self_improvement},
    {'title': 'Drink 8 glasses of water', 'done': false, 'icon': Icons.water_drop},
    {'title': 'Go for a 20-minute walk', 'done': false, 'icon': Icons.directions_walk},
    {'title': 'Read for 15 minutes', 'done': false, 'icon': Icons.menu_book},
    {'title': 'Call a friend or family member', 'done': false, 'icon': Icons.phone},
    {'title': 'Write 3 things you are grateful for', 'done': false, 'icon': Icons.edit_note},
  ];

  final List<String> _affirmations = [
    "You are capable of amazing things.",
    "Every day is a fresh start.",
    "Your mental health matters.",
    "You are stronger than you think.",
    "Small steps lead to big changes.",
    "It is okay to ask for help.",
