class BreathingTab extends StatefulWidget {
  const BreathingTab({super.key});

  @override
  State<BreathingTab> createState() => _BreathingTabState();
}

class _BreathingTabState extends State<BreathingTab>
    with SingleTickerProviderStateMixin {
  late AnimationController _breathController;
  late Animation<double> _breathAnim;

  bool _isRunning = false;
  String _phase = 'Press Start';
  int _cycleCount = 0;
  int _currentStep = 0;

  // 4-7-8 breathing: Inhale 4s, Hold 7s, Exhale 8s
  final List<Map<String, dynamic>> _steps = [
    {'label': 'Inhale', 'seconds': 4,  'color': Color(0xFF42A5F5)},
    {'label': 'Hold',   'seconds': 7,  'color': Color(0xFF7E57C2)},
    {'label': 'Exhale', 'seconds': 8,  'color': Color(0xFF26A69A)},
  ];

  int _stepSeconds = 0;
  int _elapsed = 0;

  @override
  void initState() {
    super.initState();
    _breathController = AnimationController(
      vsync: this,
      duration: const Duration(seconds: 4),
    );
    _breathAnim = Tween<double>(begin: 0.5, end: 1.0).animate(
      CurvedAnimation(parent: _breathController, curve: Curves.easeInOut),
    );
  }

  @override
  void dispose() {
    _breathController.dispose();
    super.dispose();
  }

  void _start() {
    setState(() {
      _isRunning = true;
      _currentStep = 0;
      _cycleCount = 0;
      _elapsed = 0;
    });
    _runStep(0);
  }

  void _stop() {
    _breathController.stop();
    setState(() {
      _isRunning = false;
      _phase = 'Press Start';
      _currentStep = 0;
    });
  }

  void _runStep(int stepIndex) {
    if (!_isRunning) return;
    final step = _steps[stepIndex];
    final secs = step['seconds'] as int;

    setState(() {
      _currentStep = stepIndex;
      _phase = step['label'] as String;
      _stepSeconds = secs;
      _elapsed = 0;
    });

    if (step['label'] == 'Inhale') {
      _breathController.duration = Duration(seconds: secs);
      _breathController.forward(from: 0.0);
    } else if (step['label'] == 'Exhale') {
      _breathController.duration = Duration(seconds: secs);
      _breathController.reverse(from: 1.0);
    }

    Future.delayed(Duration(seconds: secs), () {
      if (!_isRunning) return;
      final next = (stepIndex + 1) % _steps.length;
      if (next == 0) setState(() => _cycleCount++);
      _runStep(next);
    });
  }

  Color get _currentColor =>
      _isRunning ? _steps[_currentStep]['color'] as Color : kPrimaryColor;

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: kBackgroundColor,
      appBar: AppBar(
        title: const Text('Breathing Exercise',
            style: TextStyle(fontWeight: FontWeight.bold, color: kTextDark)),
        centerTitle: true,
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          children: [
            // Technique info
            _buildTechniqueCard(),
            const SizedBox(height: 30),

            // Animated breath circle
            Center(
              child: AnimatedBuilder(
                animation: _breathAnim,
                builder: (context, child) {
                  final size = 150.0 + (_breathAnim.value * 100);
                  return AnimatedContainer(
                    duration: const Duration(milliseconds: 200),
                    width: size,
                    height: size,
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      color: _currentColor.withOpacity(0.15),
                      border: Border.all(
                        color: _currentColor.withOpacity(0.5),
                        width: 3,
                      ),
                      boxShadow: [
                        BoxShadow(
                          color: _currentColor.withOpacity(0.3),
                          blurRadius: 30,
                          spreadRadius: 10,
                        ),
                      ],
                    ),
                    child: Center(
                      child: Column(
                        mainAxisSize: MainAxisSize.min,
                        children: [
                          AnimatedDefaultTextStyle(
                            duration: const Duration(milliseconds: 300),
                            style: TextStyle(
                              fontSize: _isRunning ? 20 : 16,
                              fontWeight: FontWeight.bold,
                              color: _currentColor,
                            ),
                            child: Text(_phase),
                          ),
                          if (_isRunning)
                            Text(
                              '${_steps[_currentStep]['seconds']}s',
                              style: TextStyle(
                                fontSize: 14,
                                color: _currentColor.withOpacity(0.7),
                              ),
                            ),
                        ],
                      ),
                    ),
                  );
                },
              ),
            ),
            const SizedBox(height: 30),

            // Cycles count
            if (_isRunning)
              Container(
                padding: const EdgeInsets.symmetric(
                    horizontal: 20, vertical: 10),
                decoration: BoxDecoration(
                  color: kCardColor,
                  borderRadius: BorderRadius.circular(30),
                  boxShadow: [
                    BoxShadow(
                      color: Colors.black.withOpacity(0.06),
                      blurRadius: 8,
                    ),
                  ],
                ),
                child: Text(
                  'Cycles Completed: $_cycleCount',
                  style: const TextStyle(
                    fontWeight: FontWeight.bold,
                    color: kPrimaryColor,
                    fontSize: 15,
                  ),
                ),
              ),

            const SizedBox(height: 30),

            // Steps timeline
            _buildStepsTimeline(),
            const SizedBox(height: 30),

            // Control button
            ElevatedButton.icon(
              onPressed: _isRunning ? _stop : _start,
              icon: Icon(_isRunning ? Icons.stop : Icons.play_arrow),
              label: Text(
                _isRunning ? 'Stop Exercise' : 'Start Breathing',
                style: const TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
              ),
              style: ElevatedButton.styleFrom(
                backgroundColor: _isRunning ? Colors.redAccent : kPrimaryColor,
                foregroundColor: Colors.white,
                minimumSize: const Size(double.infinity, 54),
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(14),
                ),
                elevation: 4,
              ),
            ),
            const SizedBox(height: 20),

            // Benefits
            _buildBenefitsCard(),
            const SizedBox(height: 30),
          ],
        ),
      ),
    );
  }

  Widget _buildTechniqueCard() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: kPrimaryColor.withOpacity(0.08),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: kPrimaryColor.withOpacity(0.2)),
      ),
      child: Column(
        children: [
          Row(
            children: const [
              Icon(Icons.air, color: kPrimaryColor),
              SizedBox(width: 8),
              Text(
                '4-7-8 Breathing Technique',
                style: TextStyle(
                  fontWeight: FontWeight.bold,
                  color: kTextDark,
                  fontSize: 15,
                ),
              ),
            ],
          ),
          const SizedBox(height: 8),
          const Text(
            'This technique calms your nervous system and reduces '
                'anxiety. Inhale for 4 seconds, hold for 7 seconds, '
                'then exhale slowly for 8 seconds.',
            style: TextStyle(color: kTextMid, fontSize: 13, height: 1.5),
          ),
        ],
      ),
    );
  }

  Widget _buildStepsTimeline() {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceAround,
      children: _steps.asMap().entries.map((entry) {
        final i = entry.key;
        final step = entry.value;
        final active = _isRunning && _currentStep == i;
        final color = step['color'] as Color;
        return Column(
          children: [
            AnimatedContainer(
              duration: const Duration(milliseconds: 300),
              width: active ? 60 : 50,
              height: active ? 60 : 50,
              decoration: BoxDecoration(
                color: active ? color : color.withOpacity(0.15),
                shape: BoxShape.circle,
                boxShadow: active
                    ? [BoxShadow(color: color.withOpacity(0.4), blurRadius: 12)]
                    : [],
              ),
              child: Center(
                child: Text(
                  '${step['seconds']}s',
                  style: TextStyle(
                    color: active ? Colors.white : color,
                    fontWeight: FontWeight.bold,
                    fontSize: active ? 16 : 14,
                  ),
                ),
              ),
            ),
            const SizedBox(height: 6),
            Text(
              step['label'] as String,
              style: TextStyle(
                color: active ? color : kTextMid,
                fontWeight: active ? FontWeight.bold : FontWeight.normal,
                fontSize: 12,
              ),
            ),
          ],
        );
      }).toList(),
    );
  }

  Widget _buildBenefitsCard() {
    final benefits = [
      {'icon': Icons.favorite, 'text': 'Reduces heart rate and blood pressure'},
      {'icon': Icons.psychology, 'text': 'Decreases anxiety and stress levels'},
      {'icon': Icons.nights_stay, 'text': 'Helps you fall asleep faster'},
      {'icon': Icons.energy_savings_leaf, 'text': 'Increases focus and energy'},
    ];
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: kCardColor,
        borderRadius: BorderRadius.circular(18),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.05),
            blurRadius: 8,
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Benefits of Deep Breathing',
