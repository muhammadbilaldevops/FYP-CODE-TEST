          children: [
            Container(
              width: 42,
              height: 42,
              decoration: BoxDecoration(
                color: goal['done']
                    ? kPrimaryColor.withOpacity(0.15)
                    : Colors.grey.withOpacity(0.1),
                shape: BoxShape.circle,
              ),
              child: Icon(goal['icon'],
