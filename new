    if (_count < _goal) {
      setState(() {
        _count++;
        _log.insert(
            0, 'Glass $_count  ${TimeOfDay.now().format(context)}');
      });
    }
  }

  void _removeGlass() {
    if (_count > 0) {
      setState(() {
        _log.removeAt(0);
        _count--;
      });
    }
  }

  double get _percent => _count / _goal;

