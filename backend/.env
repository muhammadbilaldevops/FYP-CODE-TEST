FLASK_ENV=development

# ============================================================
# SUPABASE DATABASE CONNECTION
# ============================================================
# PASTE YOUR SUPABASE CONNECTION STRING BELOW
# Get it from: Supabase Dashboard → Connect → ORMs → URI
# See SUPABASE_COMPLETE_GUIDE.md (Step 5) for full instructions
#
# FORMAT: postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
